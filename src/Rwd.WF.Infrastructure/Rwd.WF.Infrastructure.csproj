		<PackageReference Include="Microsoft.EntityFrameworkCore" Version="10.*" />
		<PackageReference Include="Npgsql.EntityFrameworkCore.PostgreSQL" Version="10.*" />
	</ItemGroup>

	<ItemGroup>
		<Folder Include="Persistence\Migrations\Elsa\" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\Rwd.WF.Application\Rwd.WF.Application.csproj" />
