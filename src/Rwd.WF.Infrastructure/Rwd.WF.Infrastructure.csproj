<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<Nullable>enable</Nullable>
		<ImplicitUsings>enable</ImplicitUsings>
		<AssemblyName>Rwd.WF.Infrastructure</AssemblyName>
		<RootNamespace>Rwd.WF.Infrastructure</RootNamespace>
	</PropertyGroup>

	<ItemGroup>
